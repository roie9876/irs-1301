  "salaried_worker_flow": {
    "description": "Recommended order for a salaried worker filling Form 1301",
    "steps": [
      {
        "step": 1,
        "part": "ב",
        "action": "Fill personal details — ID, address, occupation, bank account",
        "source": "ID card, bank statement"
      },
      {
        "step": 2,
        "part": "א",
        "action": "Mark filing type — joint/separate, spouse details",
        "source": "Personal knowledge"
      },
      {
        "step": 3,
        "part": "ג",
        "section": 3,
        "action": "Enter salary income from Form 106 field 158/172",
        "source": "Form 106 from employer(s)"
      },
      {
        "step": 4,
        "part": "ג",
        "section": 5,
        "action": "Enter pension/retirement amounts if applicable",
        "source": "Form 106, pension fund statements"
      },
      {
        "step": 5,
        "part": "ד",
        "action": "Enter interest/dividend income at special rates",
        "source": "Bank annual statements (טופס 867)"
      },
      {
        "step": 6,
        "part": "ה",
        "section": 24,
        "action": "Enter rental income if renting residential property",
        "source": "Rental contracts, receipts"
      },
      {
        "step": 7,
        "part": "ח",
        "action": "Enter capital gains (RSU sales, stock trades)",
        "source": "Form 1325, broker statements (E*Trade, etc.)"
      },
      {
        "step": 8,
        "part": "ט",
        "action": "Enter exempt income (exempt rental, exempt pension)",
        "source": "Calculated from earlier sections"
      },
      {
        "step": 9,
        "part": "יב",
        "action": "Enter personal deductions — pension contributions, insurance",
        "source": "Form 106 (sections 50, 53, 58, 59, 60)"
      },
      {
        "step": 10,
        "part": "יג",
        "action": "Claim credit points — children, education, donations, settlement",
        "source": "Personal knowledge, donation receipts, degree certificates"
      },
      {
        "step": 11,
        "part": "טו",
        "action": "Enter tax withheld at source (section 84 from Form 106, section 85 from banks)",
        "source": "Form 106, bank statements"
      }
    ]
  },
