  "dual_field_format": {
    "description": "Most fields use format XXX/YYY where XXX = taxpayer (נישום/בן זוג רשום) and YYY = spouse (בן/בת זוג)",
    "examples": {
      "158/172": "158 = registered spouse salary, 172 = other spouse salary",
      "206/207": "206 = registered spouse disability insurance, 207 = other spouse",
      "260/262": "260 = registered spouse children, 262 = other spouse children"
    },
    "triple_field_format": "Some fields use XXX/YYY/ZZZ where ZZZ = joint income (הכנסה משותפת)",
    "triple_examples": {
      "305/205/167": "305 = taxpayer, 205 = spouse, 167 = joint passive income",
      "311/211/060": "311 = taxpayer, 211 = spouse, 060 = joint 15% dividend"
    }
  }
